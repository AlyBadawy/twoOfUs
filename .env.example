# ─── Database (external PostgreSQL) ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=twoofus
DB_USER=twoofus
DB_PASSWORD=changeme

# ─── Authentik OIDC ────────────────────────────────────────────────────────────
# Issuer URI — the trailing slash is required for Authentik
# e.g. https://auth.example.com/application/o/twoofus/
AUTHENTIK_ISSUER_URI=

# The client_id registered in Authentik for this application
AUTHENTIK_AUDIENCE=

# ─── Claude API ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
